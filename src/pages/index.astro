---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/Hero.tsx'
import ProjectCard from '../components/ProjectCard.astro'
import { projects } from '../data/projects'
---

<Layout>
  <main>
    <section class="hero" aria-label="Apresentação">
      <Hero client:load />
    </section>

    <section id="projetos" class="projects">
      <div class="projects__intro">
        <h2 class="projects__title">// projetos</h2>
        <p class="projects__lead">
          Um ecossistema de ferramentas para RPG de mesa — de uma biblioteca de UI publicada no npm a
          um painel de controle de sessão em tempo real. Tudo autoral e aberto.
        </p>
      </div>

      <div class="grid">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <footer class="footer">
      <p>
        Feito por Felipe Lippelt ·
        <a href="https://github.com/flippelt" target="_blank" rel="noopener noreferrer">github.com/flippelt</a>
      </p>
      <p class="footer__note">
        Esta página é estática (Astro) e usa a biblioteca <code>rpg-prop-kit</code> para o visual CRT.
      </p>
    </footer>
  </main>
</Layout>
